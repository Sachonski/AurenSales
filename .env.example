# Copy this file to ".env" (or set these as real environment variables on your host).

# --- Onyx connection ---
# Your Onyx API key. While this is empty the dashboard runs in snapshot mode.
ONYX_API_KEY=

# Onyx MCP endpoint (default is correct for most orgs).
ONYX_MCP_URL=https://mcp.onyxplatform.com

# How your key is sent. Defaults send "Authorization: Bearer <key>".
# If Onyx expects a different header (e.g. X-API-Key) or a raw token, change these.
ONYX_AUTH_HEADER=Authorization
ONYX_AUTH_SCHEME=Bearer

# Native tool name on the Onyx MCP server.
ONYX_SQL_TOOL=sql_execute_query

# --- App ---
PORT=3000
# Serve cached data for this many ms so many viewers don't hammer Onyx.
CACHE_TTL_MS=10000
