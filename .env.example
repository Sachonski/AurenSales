# Copy this file to ".env" (or set these as environment variables on your host, e.g. Vercel).

# --- Onyx REST API ---
# Your Onyx API key (must have the "External user activities" resource enabled).
ONYX_API_KEY=

# Your organization slug as it appears in the API path. Confirm it in the Swagger
# "Try it out" for List current user activities. Likely "auren-health".
ONYX_ORG=

# Defaults below are correct for Onyx; only change if needed.
ONYX_API_BASE=https://api.onyxplatform.com
ONYX_AUTH_HEADER=Authorization
ONYX_AUTH_SCHEME=Bearer

# --- App ---
PORT=3000
CACHE_TTL_MS=10000
